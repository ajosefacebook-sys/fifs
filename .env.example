# FIFS - Facility Intelligence Flow System
# Environment Variables

# PostgreSQL Database (used when Prisma is connected)
DATABASE_URL="postgresql://user:password@localhost:5432/fifs"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Analytics (optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# App
NEXT_PUBLIC_APP_NAME="FIFS"
NEXT_PUBLIC_APP_ENV="development"
